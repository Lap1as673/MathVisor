# PostgreSQL
POSTGRES_USER=mathvisor
POSTGRES_PASSWORD=mathvisor123
POSTGRES_DB=mathvisor

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis
